# cerberus.env — user configuration for cerberus.sh
#
# Place this file in the same directory as cerberus.sh.
# All settings are optional; the script uses built-in defaults for anything
# not defined here, so the script runs correctly with an empty or absent file.
#
# After editing, delete /var/run/cerberus.init so that the updated
# thresholds and NEVER_STOP list are logged on the next cron cycle.

# ── Hardware context ───────────────────────────────────────────────────────
# Document your hardware here so the rationale for threshold choices is
# preserved alongside the configuration.
#
# CPU:     <model, TDP, cooling>
# Memory:  <capacity>
# Storage: <drives, RAID level>
# Notes:   <anything that affects thermal behaviour, e.g. APU GPU sharing>

# ── Thermal thresholds (°C) ────────────────────────────────────────────────
STOP_THRESHOLD=85        # Shed triggered; first app stopped
SHUTDOWN_THRESHOLD=94    # Graceful host shutdown via middleware
COOL_THRESHOLD=74        # Resume stopped apps once temperature drops to this level

# ── Logging ────────────────────────────────────────────────────────────────
LOGFILE="/path/to/logs/cerberus.log"
LOG_RETAIN_DAYS=7        # Prune log entries older than this many days each cycle

# ── Observability ──────────────────────────────────────────────────────────
# Path for the Prometheus textfile-collector metrics file.
# Must match node_exporter's --collector.textfile.directory.
# Leave empty or unset to disable metrics output entirely.
METRICSFILE="/var/run/cerberus.prom"

# ── Shedding behaviour ─────────────────────────────────────────────────────
MAX_SHED=0               # Max apps stopped per thermal event (0 = unlimited)

# ── Apps that must never be stopped ────────────────────────────────────────
# Space-separated app names to exclude from the shutdown queue entirely.
# These apps remain running even during a thermal event — use for monitoring
# agents, alerting services, or anything that keeps the system observable.
#
# Per-app alternative: add label  cerberus.override=true  to any container
# in the app's compose stack — no env file change required.
#
# Examples:
#   NEVER_STOP=("monitoring-agent")
#   NEVER_STOP=("metrics" "alerting")
NEVER_STOP=()

# ── Apps to shed last ──────────────────────────────────────────────────────
# Apps always stopped last in a thermal event, regardless of CPU load.
# Intended for GPU-intensive apps (e.g. media servers with hardware
# transcoding) whose load drives package temperature via the integrated GPU
# but does not appear in cgroup CPU accounting.
# Apps are shed in the order they appear in this array.
#
# Examples:
#   PIN_LAST=("jellyfin")
#   PIN_LAST=("jellyfin" "media-server")
PIN_LAST=()

# ── Startup dependency tiers ───────────────────────────────────────────────
# Apps are restarted tier by tier after cooling, ensuring each service's
# dependencies are available before it launches.
# Apps not listed here are started after all tiers as a catch-all.
#
# Each tier is a space-separated list of TrueNAS app names.
STARTUP_TIERS=(
  "app-a app-b"   # Tier A: no upstream dependencies
  "app-c"         # Tier B: needs app-a
  "app-d app-e"   # Tier C: needs app-b, app-c
  # Everything else starts via the catch-all after the tiers.
)